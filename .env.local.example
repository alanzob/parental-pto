# Supabase project settings — Settings -> API Keys in the dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# "Publishable key" (sb_publishable_...) — drop-in replacement for the old anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# "Secret key" (sb_secret_...) — drop-in replacement for the old service_role
# key. Server-only, NEVER exposed to the client. Used only by
# app/api/feed/[token]/feed.ics/route.ts to look up a household by its
# calendar feed token, bypassing RLS since that route is unauthenticated
# by design (calendar apps can't log in).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# Comma-separated list of emails allowed to see /dashboard/admin (growth
# metrics, the beta feedback inbox, and the error log). Leave unset to
# disable the admin page entirely. Server-only — never NEXT_PUBLIC_, since
# that would ship the allowlist in the client bundle. (ADMIN_EMAIL,
# singular, still works as a fallback for an existing deployment.)
ADMIN_EMAILS=you@example.com

# Optional. If set, new /contact submissions also post a short summary to
# this Discord webhook. https://support.discord.com/hc/en-us/articles/228383668
DISCORD_WEBHOOK_URL=
