# Supabase project settings — Settings -> API Keys in the dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# "Publishable key" (sb_publishable_...) — drop-in replacement for the old anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# "Secret key" (sb_secret_...) — drop-in replacement for the old service_role
# key. Server-only, NEVER exposed to the client. Used only by
# app/api/feed/[token]/feed.ics/route.ts to look up a household by its
# calendar feed token, bypassing RLS since that route is unauthenticated
# by design (calendar apps can't log in).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx
